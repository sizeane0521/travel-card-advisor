                    {isTop && !advice.isFull && (
                      <div className="flex flex-col items-center justify-center shrink-0"
                        style={{ width: 32, background: '#c8901a' }}>
                        <span className="text-[11px] font-bold"
                          style={{ color: '#0d0a06', writingMode: 'vertical-lr', letterSpacing: '0.15em' }}>
                          推薦
                        </span>
                      </div>
