  const inlineNumStyle = { background: '#0d0a06', borderColor: '#3a2810', color: '#c8a060' }

  // ── Task 3 & 4 & 5 & 6: Bonus list renderer ──────────────────────────────

  function renderGroupEditor(type: 'store' | 'nub', bonusIdx: number, subIdx: number | null, isDefault: boolean) {
