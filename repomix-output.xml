                  {showCategoryBrowser ? '收起分類' : '展開分類'}
                </button>
                {showCategoryBrowser && (
                  <div className="mt-2 space-y-3">
                    {bonusesWithSubs.map(({ card, bonus }) => {
                      const groupKey = `${card.id}:${bonus.storeName}`
